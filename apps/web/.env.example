AI_API_URL=http://localhost:8000
DATABASE_ADMIN_URL=postgresql://USER@localhost:5432/postgres
DATABASE_URL=postgresql://USER@localhost:5432/recommendation_system_v3
DATABASE_NAME=recommendation_system_v3

JWT_SECRET=replace-with-long-random-string-at-least-32-chars
# Testing: 30s access, then 30s refresh grace after access expires (logout ~60s from sign-in)
JWT_ACCESS_EXPIRES_IN=30s
JWT_REFRESH_EXPIRES_IN=30s

# Set automatically by npm run dev:https (enables Secure on session cookies)
# COOKIE_SECURE=true

ARCJET_KEY=
# LIVE = block requests. DRY_RUN = log only (use locally first).
ARCJET_ENV=DRY_RUN